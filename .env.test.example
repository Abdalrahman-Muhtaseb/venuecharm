# Copy to .env.test for integration/E2E tests (Phase 2+). NEVER point these at
# production. The test-setup guard rail (tests/helpers/setup.ts) refuses to run
# against a non-local, non-placeholder Supabase URL.

# Dedicated Supabase TEST project (or local `supabase start`)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe TEST-mode keys (never live keys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

PLATFORM_COMMISSION_RATE=0.15
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Escape hatch: set to true only if you knowingly test against a remote project.
# ALLOW_REAL_SUPABASE_IN_TESTS=true
