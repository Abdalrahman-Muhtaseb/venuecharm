NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=                 # "Your account" scope (payment events)
STRIPE_WEBHOOK_SECRET_CONNECT=         # "Connected accounts" scope (account.updated)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Maps: public key for the browser (Maps JS + Places), restrict to Websites/referrers.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Server-only key for Geocoding (no referrer). Code prefers this over the public key.
GOOGLE_MAPS_API_KEY=
# Google Calendar host sync (OAuth client — separate from the Maps API keys above).
# Redirect URI must be <APP_URL>/api/google/calendar/callback and registered in Google Cloud Console.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/google/calendar/callback
RESEND_API_KEY=
EMAIL_FROM="VenueCharm <onboarding@resend.dev>"   # once a domain is verified in Resend, e.g. "VenueCharm <noreply@venuecharm.com>"
# hCaptcha (optional): set to enable signup/login captcha; widget is a no-op when blank.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000          # production sets this to https://venuecharm.com in Vercel
PLATFORM_COMMISSION_RATE=0.15
# Shared secret for the Vercel Cron jobs (vercel.json): the daily birthday email
# and the daily unanswered-booking auto-cancel. Vercel sends it as an
# `Authorization: Bearer <CRON_SECRET>` header; the routes reject anything else.
CRON_SECRET=
